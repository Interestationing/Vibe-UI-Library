--[[
	Vibe UI Library (v2 — "polish" pass)
	A clean, modern UI library for Roblox scripts / executors.

	Usage:
		local Vibe = loadstring(game:HttpGet("https://raw.githubusercontent.com/<you>/<repo>/main/Vibe.lua"))()

		local Window = Vibe:CreateWindow({
			Title = "Vibe",
			Subtitle = "example script",
			ToggleKey = Enum.KeyCode.RightControl,
		})

		local Tab = Window:Tab("Main", "rbxassetid://7733960981") -- icon is optional

		Tab:Button({ Text = "Print Hello", Callback = function() print("hello") end })
		Tab:Toggle({ Text = "God Mode", Default = false, Callback = function(v) print(v) end })

	Same public API as v1 — this pass is purely visual/UX polish:
		- soft drop shadows on the window, dropdown, and notifications
		- gradient accent (indigo -> violet) instead of a flat accent color
		- animated left-edge indicator + icon support on tabs
		- glowing / springier toggle and slider
		- nicer dropdown with checkmarks and hover highlight
		- notification variants (Info / Success / Warn / Error) with colored edge
		- consistent 1px hairline strokes + subtle elevation everywhere

	MIT License. Do whatever you want with it.
]]

local TweenService     = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local Players          = game:GetService("Players")

local LocalPlayer = Players.LocalPlayer

--------------------------------------------------------------------
-- THEME
--------------------------------------------------------------------

local Theme = {
	Background   = Color3.fromRGB(17, 17, 21),
	Panel        = Color3.fromRGB(24, 24, 29),
	PanelLight   = Color3.fromRGB(31, 31, 38),
	PanelLighter = Color3.fromRGB(40, 40, 48),
	Stroke       = Color3.fromRGB(44, 44, 52),
	StrokeSoft   = Color3.fromRGB(36, 36, 43),
	Text         = Color3.fromRGB(240, 240, 245),
	SubText      = Color3.fromRGB(146, 146, 158),
	Muted        = Color3.fromRGB(100, 100, 112),

	AccentA      = Color3.fromRGB(129, 111, 255), -- violet
	AccentB      = Color3.fromRGB(92, 143, 255),  -- blue
	Accent       = Color3.fromRGB(120, 128, 255),
	AccentDim    = Color3.fromRGB(70, 76, 150),

	Good         = Color3.fromRGB(88, 210, 140),
	Warn         = Color3.fromRGB(240, 185, 90),
	Bad          = Color3.fromRGB(235, 95, 100),
	Info         = Color3.fromRGB(100, 160, 255),

	Font         = Enum.Font.GothamMedium,
	FontBold     = Enum.Font.GothamBold,
	FontSemi     = Enum.Font.GothamSemibold,

	ShadowImage  = "rbxassetid://6014261993", -- soft 9-slice shadow
}

--------------------------------------------------------------------
-- HELPERS
--------------------------------------------------------------------

local function new(class, props)
	local obj = Instance.new(class)
	for k, v in pairs(props or {}) do
		if k ~= "Parent" then
			obj[k] = v
		end
	end
	if props and props.Parent then
		obj.Parent = props.Parent
	end
	return obj
end

local function corner(parent, radius)
	return new("UICorner", { CornerRadius = UDim.new(0, radius or 8), Parent = parent })
end

local function stroke(parent, color, thickness, transparency)
	return new("UIStroke", {
		Color = color or Theme.Stroke,
		Thickness = thickness or 1,
		Transparency = transparency or 0,
		ApplyStrokeMode = Enum.ApplyStrokeMode.Border,
		Parent = parent,
	})
end

local function gradient(parent, colorSeq, rotation, transparencySeq)
	return new("UIGradient", {
		Color = colorSeq,
		Rotation = rotation or 0,
		Transparency = transparencySeq,
		Parent = parent,
	})
end

local function padding(parent, all)
	return new("UIPadding", {
		PaddingTop = UDim.new(0, all), PaddingBottom = UDim.new(0, all),
		PaddingLeft = UDim.new(0, all), PaddingRight = UDim.new(0, all),
		Parent = parent,
	})
end

-- Soft elevation shadow behind any GuiObject. Sits one layer back and scales
-- with the parent's size, so cards/panels can just call addShadow(self).
local function addShadow(parent, transparency, sizeOffset)
	local shadow = new("ImageLabel", {
		Name = "Shadow",
		Image = Theme.ShadowImage,
		ImageColor3 = Color3.new(0, 0, 0),
		ImageTransparency = transparency or 0.55,
		ScaleType = Enum.ScaleType.Slice,
		SliceCenter = Rect.new(49, 49, 450, 450),
		BackgroundTransparency = 1,
		AnchorPoint = Vector2.new(0.5, 0.5),
		Position = UDim2.new(0.5, 0, 0.5, 2),
		Size = UDim2.new(1, sizeOffset or 26, 1, sizeOffset or 26),
		ZIndex = parent.ZIndex - 1 >= 0 and parent.ZIndex - 1 or 0,
		Parent = parent,
	})
	return shadow
end

-- Accent gradient sequence reused across fills (buttons, switches, sliders).
local function accentGradient(parent, rotation)
	return gradient(parent, ColorSequence.new(Theme.AccentA, Theme.AccentB), rotation or 45)
end

local EASE_OUT   = Enum.EasingStyle.Quint
local EASE_POP   = Enum.EasingStyle.Back

local function tween(obj, props, time, style, dir)
	local t = TweenService:Create(
		obj,
		TweenInfo.new(time or 0.18, style or EASE_OUT, dir or Enum.EasingDirection.Out),
		props
	)
	t:Play()
	return t
end

local function makeDraggable(dragHandle, target)
	-- Tracks mouse/touch movement globally (not just over the handle) so fast
	-- mouse movement never "escapes" the handle and drops the drag.
	local dragging = false
	local dragInput, dragStart, startPos

	dragHandle.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			dragStart = input.Position
			startPos = target.Position

			input.Changed:Connect(function()
				if input.UserInputState == Enum.UserInputState.End then
					dragging = false
				end
			end)
		end
	end)

	dragHandle.InputChanged:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
			dragInput = input
		end
	end)

	UserInputService.InputChanged:Connect(function(input)
		if dragging and input == dragInput then
			local delta = input.Position - dragStart
			target.Position = UDim2.new(
				startPos.X.Scale, startPos.X.Offset + delta.X,
				startPos.Y.Scale, startPos.Y.Offset + delta.Y
			)
		end
	end)
end

--------------------------------------------------------------------
-- LIBRARY
--------------------------------------------------------------------

local Vibe = {}
Vibe.__index = Vibe

function Vibe:CreateWindow(config)
	config = config or {}
	local title = config.Title or "Vibe"
	local subtitle = config.Subtitle or ""
	local toggleKey = config.ToggleKey or Enum.KeyCode.RightControl

	-- root gui, parented safely whether in CoreGui (executor) or PlayerGui
	local screenGui = new("ScreenGui", {
		Name = "VibeUI_" .. tostring(math.random(1, 999999)),
		ResetOnSpawn = false,
		ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
	})

	local ok = pcall(function()
		screenGui.Parent = game:GetService("CoreGui")
	end)
	if not ok then
		screenGui.Parent = LocalPlayer:WaitForChild("PlayerGui")
	end

	local main = new("Frame", {
		Name = "Main",
		Size = UDim2.fromOffset(580, 380),
		Position = UDim2.new(0.5, -290, 0.5, -190),
		BackgroundColor3 = Theme.Background,
		BorderSizePixel = 0,
		Parent = screenGui,
	})
	corner(main, 12)
	stroke(main, Theme.Stroke, 1)
	addShadow(main, 0.5, 40)

	-- Top bar
	local topBar = new("Frame", {
		Name = "TopBar",
		Size = UDim2.new(1, 0, 0, 50),
		BackgroundColor3 = Theme.Panel,
		BorderSizePixel = 0,
		Parent = main,
	})
	corner(topBar, 12)
	-- mask the bottom corners of the topbar so it looks flush
	new("Frame", {
		Size = UDim2.new(1, 0, 0, 14),
		Position = UDim2.new(0, 0, 1, -14),
		BackgroundColor3 = Theme.Panel,
		BorderSizePixel = 0,
		Parent = topBar,
	})
	-- thin gradient accent line under the top bar
	new("Frame", {
		Name = "AccentLine",
		Size = UDim2.new(1, 0, 0, 2),
		Position = UDim2.new(0, 0, 1, 0),
		BorderSizePixel = 0,
		BackgroundColor3 = Color3.new(1, 1, 1),
		Parent = topBar,
	}).BackgroundTransparency = 0
	accentGradient(topBar:FindFirstChild("AccentLine"), 0)

	-- small logo dot with accent gradient
	local logoDot = new("Frame", {
		Size = UDim2.fromOffset(10, 10),
		Position = UDim2.fromOffset(18, 20),
		BackgroundColor3 = Color3.new(1, 1, 1),
		Parent = topBar,
	})
	corner(logoDot, 5)
	accentGradient(logoDot, 90)

	new("TextLabel", {
		Text = title,
		Font = Theme.FontBold,
		TextSize = 16,
		TextColor3 = Theme.Text,
		BackgroundTransparency = 1,
		TextXAlignment = Enum.TextXAlignment.Left,
		Position = UDim2.fromOffset(36, 8),
		Size = UDim2.new(1, -120, 0, 20),
		Parent = topBar,
	})

	new("TextLabel", {
		Text = subtitle,
		Font = Theme.Font,
		TextSize = 12,
		TextColor3 = Theme.SubText,
		BackgroundTransparency = 1,
		TextXAlignment = Enum.TextXAlignment.Left,
		Position = UDim2.fromOffset(36, 27),
		Size = UDim2.new(1, -120, 0, 16),
		Parent = topBar,
	})

	local closeBtn = new("TextButton", {
		Text = "X",
		Font = Theme.FontBold,
		TextSize = 14,
		TextColor3 = Theme.SubText,
		BackgroundColor3 = Theme.PanelLight,
		BackgroundTransparency = 1,
		AutoButtonColor = false,
		Size = UDim2.fromOffset(30, 30),
		Position = UDim2.new(1, -40, 0.5, -15),
		Parent = topBar,
	})
	corner(closeBtn, 8)
	closeBtn.MouseButton1Click:Connect(function()
		main.Visible = false
	end)
	closeBtn.MouseEnter:Connect(function()
		tween(closeBtn, { BackgroundTransparency = 0, TextColor3 = Theme.Text, BackgroundColor3 = Theme.Bad }, 0.12)
	end)
	closeBtn.MouseLeave:Connect(function()
		tween(closeBtn, { BackgroundTransparency = 1, TextColor3 = Theme.SubText }, 0.12)
	end)

	makeDraggable(topBar, main)

	-- Sidebar (tab list)
	local sidebar = new("Frame", {
		Name = "Sidebar",
		Size = UDim2.new(0, 150, 1, -50),
		Position = UDim2.new(0, 0, 0, 50),
		BackgroundColor3 = Theme.Panel,
		BorderSizePixel = 0,
		Parent = main,
	})
	-- hairline divider between sidebar and content. NOTE: this is parented to
	-- `main`, not `sidebar` — sidebar has a UIListLayout below, and anything
	-- parented inside it gets swept into that vertical stack too.
	new("Frame", {
		Size = UDim2.new(0, 1, 1, -50),
		Position = UDim2.new(0, 149, 0, 50),
		BackgroundColor3 = Theme.StrokeSoft,
		BorderSizePixel = 0,
		Parent = main,
	})

	local tabList = new("UIListLayout", {
		Padding = UDim.new(0, 4),
		SortOrder = Enum.SortOrder.LayoutOrder,
		Parent = sidebar,
	})
	padding(sidebar, 10)

	-- Content area
	local contentHolder = new("Frame", {
		Name = "Content",
		Size = UDim2.new(1, -150, 1, -50),
		Position = UDim2.new(0, 150, 0, 50),
		BackgroundTransparency = 1,
		Parent = main,
	})

	-- Notifications holder
	local notifHolder = new("Frame", {
		Name = "Notifications",
		AnchorPoint = Vector2.new(1, 1),
		Position = UDim2.new(1, -16, 1, -16),
		Size = UDim2.fromOffset(300, 420),
		BackgroundTransparency = 1,
		Parent = screenGui,
	})
	new("UIListLayout", {
		Padding = UDim.new(0, 8),
		VerticalAlignment = Enum.VerticalAlignment.Bottom,
		HorizontalAlignment = Enum.HorizontalAlignment.Right,
		SortOrder = Enum.SortOrder.LayoutOrder,
		Parent = notifHolder,
	})

	-- Overlay: a full-screen, top-level layer used for things that must never
	-- be clipped by a ScrollingFrame (currently: open dropdown lists).
	local overlay = new("Frame", {
		Name = "Overlay",
		BackgroundTransparency = 1,
		Size = UDim2.fromScale(1, 1),
		ZIndex = 100,
		Parent = screenGui,
	})

	-- Invisible full-screen button that sits just under any open dropdown list.
	-- Clicking anywhere outside the list hits this and closes it.
	local dropdownCatcher = new("TextButton", {
		Name = "DropdownCatcher",
		Text = "",
		AutoButtonColor = false,
		BackgroundTransparency = 1,
		Size = UDim2.fromScale(1, 1),
		Visible = false,
		ZIndex = 99,
		Parent = overlay,
	})

	-- toggle visibility keybind(s). Delete always works as a failsafe hide/show,
	-- in addition to whatever custom ToggleKey was configured.
	UserInputService.InputBegan:Connect(function(input, gpe)
		if gpe then return end
		if input.KeyCode == toggleKey or input.KeyCode == Enum.KeyCode.Delete then
			main.Visible = not main.Visible
		end
	end)

	-- gentle entrance animation
	main.Size = UDim2.fromOffset(580, 0)
	tween(main, { Size = UDim2.fromOffset(580, 380) }, 0.25, EASE_POP)

	local self = setmetatable({
		ScreenGui = screenGui,
		Main = main,
		Sidebar = sidebar,
		ContentHolder = contentHolder,
		NotifHolder = notifHolder,
		Overlay = overlay,
		DropdownCatcher = dropdownCatcher,
		Tabs = {},
		_firstTab = true,
		_closeOpenDropdown = nil,
	}, Vibe)

	dropdownCatcher.MouseButton1Click:Connect(function()
		if self._closeOpenDropdown then
			self._closeOpenDropdown()
		end
	end)

	return self
end

local NOTIF_STYLES = {
	Info    = Theme.Info,
	Success = Theme.Good,
	Warn    = Theme.Warn,
	Error   = Theme.Bad,
}

function Vibe:Notify(config)
	config = config or {}
	local title = config.Title or "Notification"
	local text = config.Text or ""
	local duration = config.Duration or 3.5
	local kind = config.Type or "Info"
	local edgeColor = NOTIF_STYLES[kind] or Theme.Info

	local notif = new("Frame", {
		Size = UDim2.new(1, 0, 0, 0),
		AutomaticSize = Enum.AutomaticSize.Y,
		BackgroundColor3 = Theme.Panel,
		BorderSizePixel = 0,
		ClipsDescendants = true,
		LayoutOrder = -os.clock(),
		Parent = self.NotifHolder,
	})
	corner(notif, 10)
	stroke(notif, Theme.Stroke, 1)
	addShadow(notif, 0.6, 20)

	new("Frame", { -- colored edge indicator
		Size = UDim2.new(0, 3, 1, 0),
		BackgroundColor3 = edgeColor,
		BorderSizePixel = 0,
		Parent = notif,
	})

	local inner = new("Frame", {
		Size = UDim2.new(1, 0, 0, 0),
		AutomaticSize = Enum.AutomaticSize.Y,
		BackgroundTransparency = 1,
		Parent = notif,
	})
	padding(inner, 12)

	new("UIListLayout", {
		Padding = UDim.new(0, 2),
		SortOrder = Enum.SortOrder.LayoutOrder,
		Parent = inner,
	})

	new("TextLabel", {
		Text = title,
		Font = Theme.FontBold,
		TextSize = 14,
		TextColor3 = Theme.Text,
		BackgroundTransparency = 1,
		TextXAlignment = Enum.TextXAlignment.Left,
		Size = UDim2.new(1, 0, 0, 18),
		AutomaticSize = Enum.AutomaticSize.Y,
		Parent = inner,
	})

	new("TextLabel", {
		Text = text,
		Font = Theme.Font,
		TextSize = 13,
		TextColor3 = Theme.SubText,
		BackgroundTransparency = 1,
		TextXAlignment = Enum.TextXAlignment.Left,
		TextWrapped = true,
		Size = UDim2.new(1, 0, 0, 0),
		AutomaticSize = Enum.AutomaticSize.Y,
		Parent = inner,
	})

	notif.BackgroundTransparency = 1
	notif.Position = UDim2.new(0, 30, 0, 0)
	tween(notif, { BackgroundTransparency = 0, Position = UDim2.new(0, 0, 0, 0) }, 0.22, EASE_POP)

	task.delay(duration, function()
		if notif and notif.Parent then
			tween(notif, { BackgroundTransparency = 1, Position = UDim2.new(0, 30, 0, 0) }, 0.2)
			task.wait(0.2)
			notif:Destroy()
		end
	end)
end

--------------------------------------------------------------------
-- TABS
--------------------------------------------------------------------

local Tab = {}
Tab.__index = Tab

function Vibe:CreateTab(name, icon)
	name = name or "Tab"

	local btn = new("TextButton", {
		Name = name .. "TabButton",
		Text = "",
		AutoButtonColor = false,
		BackgroundColor3 = Theme.PanelLighter,
		BackgroundTransparency = 1,
		Size = UDim2.new(1, 0, 0, 36),
		Parent = self.Sidebar,
	})
	corner(btn, 8)

	-- animated left accent indicator
	local indicator = new("Frame", {
		Name = "Indicator",
		Size = UDim2.new(0, 3, 0, 0),
		AnchorPoint = Vector2.new(0, 0.5),
		Position = UDim2.new(0, 0, 0.5, 0),
		BackgroundColor3 = Color3.new(1, 1, 1),
		BorderSizePixel = 0,
		Parent = btn,
	})
	corner(indicator, 2)
	accentGradient(indicator, 90)

	local iconOffset = icon and 34 or 14
	local iconImg
	if icon then
		iconImg = new("ImageLabel", {
			Image = icon,
			BackgroundTransparency = 1,
			ImageColor3 = Theme.SubText,
			Size = UDim2.fromOffset(16, 16),
			Position = UDim2.fromOffset(12, 10),
			Parent = btn,
		})
	end

	local label = new("TextLabel", {
		Text = name,
		Font = Theme.Font,
		TextSize = 13,
		TextColor3 = Theme.SubText,
		BackgroundTransparency = 1,
		TextXAlignment = Enum.TextXAlignment.Left,
		Position = UDim2.fromOffset(iconOffset, 0),
		Size = UDim2.new(1, -iconOffset - 10, 1, 0),
		Parent = btn,
	})

	local page = new("ScrollingFrame", {
		Name = name .. "Page",
		Size = UDim2.new(1, 0, 1, 0),
		BackgroundTransparency = 1,
		BorderSizePixel = 0,
		ScrollBarThickness = 3,
		ScrollBarImageColor3 = Theme.Accent,
		CanvasSize = UDim2.new(0, 0, 0, 0),
		AutomaticCanvasSize = Enum.AutomaticSize.Y,
		Visible = false,
		Parent = self.ContentHolder,
	})
	padding(page, 16)
	new("UIListLayout", {
		Padding = UDim.new(0, 8),
		SortOrder = Enum.SortOrder.LayoutOrder,
		Parent = page,
	})

	local tabObj = setmetatable({
		Button = btn,
		Page = page,
		Indicator = indicator,
		Icon = iconImg,
		Label = label,
		_window = self,
	}, Tab)

	table.insert(self.Tabs, tabObj)

	local function selectTab()
		for _, t in ipairs(self.Tabs) do
			t.Page.Visible = false
			tween(t.Button, { BackgroundTransparency = 1 }, 0.15)
			tween(t.Label, { TextColor3 = Theme.SubText }, 0.15)
			tween(t.Indicator, { Size = UDim2.new(0, 3, 0, 0) }, 0.15)
			if t.Icon then tween(t.Icon, { ImageColor3 = Theme.SubText }, 0.15) end
		end
		page.Visible = true
		tween(btn, { BackgroundTransparency = 0 }, 0.15)
		tween(label, { TextColor3 = Theme.Text }, 0.15)
		tween(indicator, { Size = UDim2.new(0, 3, 0, 18) }, 0.18, EASE_POP)
		if iconImg then tween(iconImg, { ImageColor3 = Theme.Accent }, 0.15) end
	end

	btn.MouseEnter:Connect(function()
		if not page.Visible then tween(btn, { BackgroundTransparency = 0.6 }, 0.12) end
	end)
	btn.MouseLeave:Connect(function()
		if not page.Visible then tween(btn, { BackgroundTransparency = 1 }, 0.12) end
	end)
	btn.MouseButton1Click:Connect(selectTab)

	if self._firstTab then
		self._firstTab = false
		selectTab()
	end

	return tabObj
end

Vibe.Tab = Vibe.CreateTab -- alias: Window:Tab("Main", icon) == Window:CreateTab("Main", icon)

--------------------------------------------------------------------
-- ELEMENT: Section (visual grouping, optional)
--------------------------------------------------------------------

local function baseCard(parent, height)
	local card = new("Frame", {
		Size = UDim2.new(1, 0, 0, height or 40),
		BackgroundColor3 = Theme.Panel,
		BorderSizePixel = 0,
		Parent = parent,
	})
	corner(card, 9)
	stroke(card, Theme.Stroke, 1)
	return card
end

function Tab:Section(title)
	local holder = new("Frame", {
		Size = UDim2.new(1, 0, 0, 26),
		BackgroundTransparency = 1,
		Parent = self.Page,
	})
	local dot = new("Frame", {
		Size = UDim2.fromOffset(4, 4),
		Position = UDim2.new(0, 0, 0.5, -2),
		BackgroundColor3 = Theme.Muted,
		Parent = holder,
	})
	corner(dot, 2)
	new("TextLabel", {
		Text = string.upper(title),
		Font = Theme.FontSemi,
		TextSize = 11,
		TextColor3 = Theme.Muted,
		BackgroundTransparency = 1,
		TextXAlignment = Enum.TextXAlignment.Left,
		Position = UDim2.fromOffset(12, 0),
		Size = UDim2.new(1, -12, 1, 0),
		Parent = holder,
	})
	return holder
end

--------------------------------------------------------------------
-- ELEMENT: Label
--------------------------------------------------------------------

function Tab:Label(text)
	local card = baseCard(self.Page, 36)
	new("TextLabel", {
		Text = text,
		Font = Theme.Font,
		TextSize = 13,
		TextColor3 = Theme.Text,
		BackgroundTransparency = 1,
		TextXAlignment = Enum.TextXAlignment.Left,
		Size = UDim2.new(1, -20, 1, 0),
		Position = UDim2.fromOffset(12, 0),
		Parent = card,
	})
	return {
		Set = function(_, newText)
			card:FindFirstChildOfClass("TextLabel").Text = newText
		end,
	}
end

--------------------------------------------------------------------
-- ELEMENT: Button
--------------------------------------------------------------------

function Tab:Button(config)
	config = config or {}
	local text = config.Text or "Button"
	local callback = config.Callback or function() end

	local card = baseCard(self.Page, 42)

	local btn = new("TextButton", {
		Text = text,
		Font = Theme.FontSemi,
		TextSize = 13,
		TextColor3 = Theme.Text,
		AutoButtonColor = false,
		BackgroundTransparency = 1,
		Size = UDim2.new(1, 0, 1, 0),
		Parent = card,
	})

	btn.MouseEnter:Connect(function() tween(card, { BackgroundColor3 = Theme.PanelLighter }, 0.12) end)
	btn.MouseLeave:Connect(function() tween(card, { BackgroundColor3 = Theme.Panel }, 0.12) end)
	btn.MouseButton1Click:Connect(function()
		tween(card, { BackgroundColor3 = Theme.AccentDim }, 0.06)
		task.delay(0.09, function()
			tween(card, { BackgroundColor3 = Theme.Panel }, 0.18)
		end)
		local ok, err = pcall(callback)
		if not ok then warn("[Vibe] Button callback error: " .. tostring(err)) end
	end)

	return { Instance = card }
end

--------------------------------------------------------------------
-- ELEMENT: Toggle
--------------------------------------------------------------------

function Tab:Toggle(config)
	config = config or {}
	local text = config.Text or "Toggle"
	local default = config.Default or false
	local callback = config.Callback or function() end

	local card = baseCard(self.Page, 42)

	new("TextLabel", {
		Text = text,
		Font = Theme.Font,
		TextSize = 13,
		TextColor3 = Theme.Text,
		BackgroundTransparency = 1,
		TextXAlignment = Enum.TextXAlignment.Left,
		Size = UDim2.new(1, -74, 1, 0),
		Position = UDim2.fromOffset(12, 0),
		Parent = card,
	})

	local switchBg = new("Frame", {
		Size = UDim2.fromOffset(42, 24),
		Position = UDim2.new(1, -54, 0.5, -12),
		BackgroundColor3 = default and Theme.AccentB or Theme.PanelLighter,
		Parent = card,
	})
	corner(switchBg, 12)
	stroke(switchBg, Theme.Stroke, 1)
	if default then accentGradient(switchBg, 0) end

	local knob = new("Frame", {
		Size = UDim2.fromOffset(18, 18),
		Position = default and UDim2.new(1, -21, 0.5, -9) or UDim2.new(0, 3, 0.5, -9),
		BackgroundColor3 = Color3.fromRGB(255, 255, 255),
		Parent = switchBg,
	})
	corner(knob, 9)
	addShadow(knob, 0.75, 10)

	local clickArea = new("TextButton", {
		Text = "",
		AutoButtonColor = false,
		BackgroundTransparency = 1,
		Size = UDim2.new(1, 0, 1, 0),
		Parent = card,
	})

	local state = default
	local grad = switchBg:FindFirstChildOfClass("UIGradient")

	local function set(value, fire)
		state = value
		if state then
			if not grad then grad = accentGradient(switchBg, 0) end
			tween(switchBg, { BackgroundColor3 = Theme.AccentB }, 0.15)
			tween(knob, { Position = UDim2.new(1, -21, 0.5, -9) }, 0.16, EASE_POP)
		else
			if grad then grad:Destroy(); grad = nil end
			tween(switchBg, { BackgroundColor3 = Theme.PanelLighter }, 0.15)
			tween(knob, { Position = UDim2.new(0, 3, 0.5, -9) }, 0.16, EASE_POP)
		end
		if fire ~= false then
			local ok, err = pcall(callback, state)
			if not ok then warn("[Vibe] Toggle callback error: " .. tostring(err)) end
		end
	end

	clickArea.MouseButton1Click:Connect(function()
		set(not state)
	end)

	if default then
		pcall(callback, default)
	end

	return {
		Set = function(_, value) set(value) end,
		Get = function() return state end,
	}
end

--------------------------------------------------------------------
-- ELEMENT: Slider
--------------------------------------------------------------------

function Tab:Slider(config)
	config = config or {}
	local text = config.Text or "Slider"
	local min = config.Min or 0
	local max = config.Max or 100
	local default = math.clamp(config.Default or min, min, max)
	local decimals = config.Decimals or 0
	local suffix = config.Suffix or ""
	local callback = config.Callback or function() end

	local card = baseCard(self.Page, 52)

	new("TextLabel", {
		Text = text,
		Font = Theme.Font,
		TextSize = 13,
		TextColor3 = Theme.Text,
		BackgroundTransparency = 1,
		TextXAlignment = Enum.TextXAlignment.Left,
		Size = UDim2.new(1, -90, 0, 20),
		Position = UDim2.fromOffset(12, 6),
		Parent = card,
	})

	local valueLabel = new("TextLabel", {
		Text = tostring(default) .. suffix,
		Font = Theme.FontBold,
		TextSize = 13,
		TextColor3 = Theme.Accent,
		BackgroundTransparency = 1,
		TextXAlignment = Enum.TextXAlignment.Right,
		Size = UDim2.fromOffset(70, 20),
		Position = UDim2.new(1, -82, 0, 6),
		Parent = card,
	})

	local track = new("Frame", {
		Size = UDim2.new(1, -24, 0, 6),
		Position = UDim2.fromOffset(12, 34),
		BackgroundColor3 = Theme.PanelLighter,
		Parent = card,
	})
	corner(track, 3)

	local fraction = (default - min) / (max - min)
	local fill = new("Frame", {
		Size = UDim2.new(fraction, 0, 1, 0),
		BackgroundColor3 = Color3.new(1, 1, 1),
		Parent = track,
	})
	corner(fill, 3)
	accentGradient(fill, 0)

	-- draggable knob that rides the fill edge for a more tactile feel
	local knob = new("Frame", {
		AnchorPoint = Vector2.new(0.5, 0.5),
		Size = UDim2.fromOffset(14, 14),
		Position = UDim2.new(fraction, 0, 0.5, 0),
		BackgroundColor3 = Color3.fromRGB(255, 255, 255),
		ZIndex = 2,
		Parent = track,
	})
	corner(knob, 7)
	addShadow(knob, 0.7, 8)

	local dragging = false

	local function round(n)
		local mult = 10 ^ decimals
		local result = math.floor(n * mult + 0.5) / mult
		if decimals == 0 then result = math.floor(n + 0.5) end
		return result
	end

	local function update(inputPos)
		local relX = math.clamp((inputPos.X - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
		local value = round(min + (max - min) * relX)
		local frac = (value - min) / (max - min)
		fill.Size = UDim2.new(frac, 0, 1, 0)
		knob.Position = UDim2.new(frac, 0, 0.5, 0)
		valueLabel.Text = tostring(value) .. suffix
		local ok, err = pcall(callback, value)
		if not ok then warn("[Vibe] Slider callback error: " .. tostring(err)) end
		return value
	end

	track.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			tween(knob, { Size = UDim2.fromOffset(18, 18) }, 0.12)
			update(input.Position)
		end
	end)
	UserInputService.InputChanged:Connect(function(input)
		if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
			update(input.Position)
		end
	end)
	UserInputService.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			if dragging then tween(knob, { Size = UDim2.fromOffset(14, 14) }, 0.12) end
			dragging = false
		end
	end)

	return {
		Set = function(_, value)
			value = math.clamp(value, min, max)
			local frac = (value - min) / (max - min)
			fill.Size = UDim2.new(frac, 0, 1, 0)
			knob.Position = UDim2.new(frac, 0, 0.5, 0)
			valueLabel.Text = tostring(value) .. suffix
		end,
	}
end

--------------------------------------------------------------------
-- ELEMENT: Dropdown
--------------------------------------------------------------------

function Tab:Dropdown(config)
	config = config or {}
	local text = config.Text or "Dropdown"
	local options = config.Options or {}
	local default = config.Default
	local callback = config.Callback or function() end

	local window = self._window

	local card = baseCard(self.Page, 42)

	new("TextLabel", {
		Text = text,
		Font = Theme.Font,
		TextSize = 13,
		TextColor3 = Theme.Text,
		BackgroundTransparency = 1,
		TextXAlignment = Enum.TextXAlignment.Left,
		Size = UDim2.new(0.5, 0, 1, 0),
		Position = UDim2.fromOffset(12, 0),
		Parent = card,
	})

	local selectedLabel = new("TextLabel", {
		Text = default or "Select...",
		Font = Theme.FontSemi,
		TextSize = 13,
		TextColor3 = default and Theme.Accent or Theme.SubText,
		BackgroundTransparency = 1,
		TextXAlignment = Enum.TextXAlignment.Right,
		Size = UDim2.new(0.5, -30, 1, 0),
		Position = UDim2.new(0.5, 0, 0, 0),
		Parent = card,
	})

	-- "v" / "^" instead of unicode triangles: those glyphs aren't included in
	-- Roblox's built-in fonts and render as blank boxes.
	local arrow = new("TextLabel", {
		Text = "v",
		Font = Theme.FontBold,
		TextSize = 13,
		TextColor3 = Theme.SubText,
		BackgroundTransparency = 1,
		Size = UDim2.fromOffset(20, 42),
		Position = UDim2.new(1, -24, 0, 0),
		Parent = card,
	})

	local clickArea = new("TextButton", {
		Text = "",
		AutoButtonColor = false,
		BackgroundTransparency = 1,
		Size = UDim2.new(1, 0, 1, 0),
		Parent = card,
	})

	-- The option list lives in the window's top-level Overlay, NOT inside the
	-- scrolling tab content, so it is never clipped and always renders fully
	-- on top regardless of where the card sits in the scroll view.
	local list = new("Frame", {
		Name = "DropdownList",
		BackgroundColor3 = Theme.PanelLighter,
		Visible = false,
		ClipsDescendants = true,
		ZIndex = 100,
		Parent = window.Overlay,
	})
	corner(list, 9)
	stroke(list, Theme.Stroke, 1)
	local listShadow = addShadow(list, 0.55, 20)
	listShadow.ZIndex = 1 -- must stay below the option rows (see buildOptions)
	local listPad = padding(list, 4)
	new("UIListLayout", {
		Padding = UDim.new(0, 2),
		SortOrder = Enum.SortOrder.LayoutOrder,
		Parent = list,
	})

	local open = false
	local ROW_HEIGHT = 30
	local MAX_VISIBLE = 5
	local selectedValue = default

	local function closeDropdown()
		if not open then return end
		open = false
		arrow.Text = "v"
		tween(arrow, { Rotation = 0 }, 0.15)
		tween(list, { Size = UDim2.new(0, list.AbsoluteSize.X, 0, 0) }, 0.15)
		window.DropdownCatcher.Visible = false
		window._closeOpenDropdown = nil
		task.delay(0.16, function()
			if not open then list.Visible = false end
		end)
	end

	local function positionList()
		local absPos = card.AbsolutePosition
		local absSize = card.AbsoluteSize
		list.Position = UDim2.fromOffset(absPos.X, absPos.Y + absSize.Y + 6)
		list.Size = UDim2.new(0, absSize.X, 0, list.Size.Y.Offset)
	end

	local function buildOptions(opts)
		for _, child in ipairs(list:GetChildren()) do
			if child.Name == "OptionRow" then child:Destroy() end
		end
		for _, opt in ipairs(opts) do
			local row = new("Frame", {
				Name = "OptionRow",
				Size = UDim2.new(1, 0, 0, ROW_HEIGHT),
				BackgroundTransparency = 1,
				ZIndex = 3, -- must stay above listShadow (ZIndex 1)
				Parent = list,
			})
			corner(row, 6)

			local optBtn = new("TextButton", {
				Text = "",
				AutoButtonColor = false,
				BackgroundTransparency = 1,
				Size = UDim2.new(1, 0, 1, 0),
				ZIndex = 4,
				Parent = row,
			})

			new("TextLabel", {
				Text = tostring(opt),
				Font = Theme.Font,
				TextSize = 13,
				TextColor3 = Theme.Text,
				BackgroundTransparency = 1,
				TextXAlignment = Enum.TextXAlignment.Left,
				Position = UDim2.fromOffset(10, 0),
				Size = UDim2.new(1, -34, 1, 0),
				ZIndex = 4,
				Parent = row,
			})

			-- plain color-filled dot instead of an image asset for the
			-- "selected" mark, so it never depends on an asset loading
			local check = new("Frame", {
				BackgroundColor3 = Theme.Accent,
				Visible = (tostring(opt) == tostring(selectedValue)),
				Size = UDim2.fromOffset(6, 6),
				Position = UDim2.new(1, -18, 0.5, -3),
				ZIndex = 4,
				Parent = row,
			})
			corner(check, 3)

			optBtn.MouseEnter:Connect(function() tween(row, { BackgroundTransparency = 0.85, BackgroundColor3 = Theme.Accent }, 0.1) end)
			optBtn.MouseLeave:Connect(function() tween(row, { BackgroundTransparency = 1 }, 0.1) end)
			optBtn.MouseButton1Click:Connect(function()
				selectedValue = opt
				selectedLabel.Text = tostring(opt)
				selectedLabel.TextColor3 = Theme.Accent
				for _, r in ipairs(list:GetChildren()) do
					if r:IsA("Frame") then
						local c = r:FindFirstChild("Frame")
						if c then c.Visible = (r == row) end
					end
				end
				closeDropdown()
				local ok, err = pcall(callback, opt)
				if not ok then warn("[Vibe] Dropdown callback error: " .. tostring(err)) end
			end)
		end
	end

	buildOptions(options)

	clickArea.MouseButton1Click:Connect(function()
		if open then
			closeDropdown()
			return
		end
		-- close any other dropdown that's currently open first
		if window._closeOpenDropdown then
			window._closeOpenDropdown()
		end

		open = true
		positionList()
		list.Visible = true
		arrow.Text = "^"
		window.DropdownCatcher.Visible = true
		window._closeOpenDropdown = closeDropdown

		local target = math.min(#options, MAX_VISIBLE) * ROW_HEIGHT + 8
		tween(list, { Size = UDim2.new(0, card.AbsoluteSize.X, 0, target) }, 0.16, EASE_POP)
	end)

	if default then
		pcall(callback, default)
	end

	return {
		Set = function(_, value)
			selectedValue = value
			selectedLabel.Text = tostring(value)
			selectedLabel.TextColor3 = Theme.Accent
		end,
		Refresh = function(_, newOptions)
			options = newOptions
			buildOptions(options)
		end,
	}
end

--------------------------------------------------------------------
-- ELEMENT: TextInput
--------------------------------------------------------------------

function Tab:Input(config)
	config = config or {}
	local text = config.Text or "Input"
	local placeholder = config.Placeholder or "..."
	local default = config.Default or ""
	local callback = config.Callback or function() end

	local card = baseCard(self.Page, 42)

	new("TextLabel", {
		Text = text,
		Font = Theme.Font,
		TextSize = 13,
		TextColor3 = Theme.Text,
		BackgroundTransparency = 1,
		TextXAlignment = Enum.TextXAlignment.Left,
		Size = UDim2.new(0.4, 0, 1, 0),
		Position = UDim2.fromOffset(12, 0),
		Parent = card,
	})

	local boxHolder = new("Frame", {
		Size = UDim2.new(0.5, -12, 0, 30),
		Position = UDim2.new(0.5, 0, 0.5, -15),
		BackgroundColor3 = Theme.PanelLighter,
		Parent = card,
	})
	corner(boxHolder, 7)
	local boxStroke = stroke(boxHolder, Theme.Stroke, 1)

	local box = new("TextBox", {
		Text = default,
		PlaceholderText = placeholder,
		Font = Theme.Font,
		TextSize = 13,
		TextColor3 = Theme.Text,
		PlaceholderColor3 = Theme.Muted,
		BackgroundTransparency = 1,
		ClearTextOnFocus = false,
		Size = UDim2.new(1, 0, 1, 0),
		Parent = boxHolder,
	})
	padding(box, 8)

	box.Focused:Connect(function()
		tween(boxStroke, { Color = Theme.AccentB }, 0.12)
	end)
	box.FocusLost:Connect(function(enterPressed)
		tween(boxStroke, { Color = Theme.Stroke }, 0.12)
		local ok, err = pcall(callback, box.Text, enterPressed)
		if not ok then warn("[Vibe] Input callback error: " .. tostring(err)) end
	end)

	return {
		Set = function(_, value) box.Text = value end,
		Get = function() return box.Text end,
	}
end

--------------------------------------------------------------------
-- ELEMENT: Keybind
--------------------------------------------------------------------

function Tab:Keybind(config)
	config = config or {}
	local text = config.Text or "Keybind"
	local default = config.Default or Enum.KeyCode.F
	local callback = config.Callback or function() end

	local card = baseCard(self.Page, 42)

	new("TextLabel", {
		Text = text,
		Font = Theme.Font,
		TextSize = 13,
		TextColor3 = Theme.Text,
		BackgroundTransparency = 1,
		TextXAlignment = Enum.TextXAlignment.Left,
		Size = UDim2.new(1, -100, 1, 0),
		Position = UDim2.fromOffset(12, 0),
		Parent = card,
	})

	local keyBtn = new("TextButton", {
		Text = default.Name,
		Font = Theme.FontBold,
		TextSize = 13,
		TextColor3 = Theme.Accent,
		BackgroundColor3 = Theme.PanelLighter,
		AutoButtonColor = false,
		Size = UDim2.fromOffset(84, 30),
		Position = UDim2.new(1, -96, 0.5, -15),
		Parent = card,
	})
	corner(keyBtn, 7)
	stroke(keyBtn, Theme.Stroke, 1)

	local currentKey = default
	local listening = false

	keyBtn.MouseButton1Click:Connect(function()
		listening = true
		keyBtn.Text = "..."
		tween(keyBtn, { BackgroundColor3 = Theme.AccentDim }, 0.12)
	end)

	UserInputService.InputBegan:Connect(function(input, gpe)
		if listening and input.UserInputType == Enum.UserInputType.Keyboard then
			currentKey = input.KeyCode
			keyBtn.Text = currentKey.Name
			listening = false
			tween(keyBtn, { BackgroundColor3 = Theme.PanelLighter }, 0.15)
		elseif not gpe and input.KeyCode == currentKey then
			tween(keyBtn, { BackgroundColor3 = Theme.AccentDim }, 0.08)
			task.delay(0.1, function() tween(keyBtn, { BackgroundColor3 = Theme.PanelLighter }, 0.18) end)
			local ok, err = pcall(callback, currentKey)
			if not ok then warn("[Vibe] Keybind callback error: " .. tostring(err)) end
		end
	end)

	return {
		Set = function(_, keyCode) currentKey = keyCode; keyBtn.Text = keyCode.Name end,
		Get = function() return currentKey end,
	}
end

return Vibe
